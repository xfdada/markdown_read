# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
document/
wheels/
*.egg-info

# Virtual environments
.venv

# PyInstaller spec (auto-generated, not needed in VCS)
*.spec

# Large release archives — never commit these
*.zip
*.tar.gz

# Runtime config — contains file_key + password_hash (secrets)
# Use config.template.json as the committable version
config.json
